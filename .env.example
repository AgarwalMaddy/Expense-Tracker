# Neon Postgres connection string
# Get this from: Neon Console → Project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Neon Auth base URL
# Get this from: Neon Console → Project → Auth → Settings
NEON_AUTH_BASE_URL="https://auth.xxx.neon.tech"

# Cookie secret for Neon Auth session encryption
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="your-random-32-byte-base64-string"
